# Required: GitHub PAT for scanning public repos
# Create a fine-grained PAT with Public Repositories (read-only) access
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Rate limiting via Vercel KV or Upstash Redis
# If not set, rate limiting is disabled (fine for local dev)
# Vercel KV (auto-provisioned in Vercel dashboard):
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Or Upstash Redis (free tier at upstash.com):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
