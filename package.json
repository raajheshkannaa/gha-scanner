{
  "name": "gha-scanner",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "gha-scanner": "./dist/cli.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cli": "npx esbuild src/cli.ts --bundle --platform=node --target=node18 --outfile=dist/cli.js --format=cjs --banner:js='#!/usr/bin/env node'",
    "build:action": "npx esbuild src/action.ts --bundle --platform=node --target=node20 --outfile=dist/action.js --format=cjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "lucide-react": "^0.577.0",
    "next": "^15.5.14",
    "p-limit": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "eslint": "^8",
    "eslint-config-next": "^15.5.14",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
